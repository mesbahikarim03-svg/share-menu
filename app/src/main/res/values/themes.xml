<?xml version="1.0" encoding="utf-8"?>
  <resources>
      <!-- Base Material-3 theme used by the BottomSheetDialogFragment -->
      <style name="Theme.ShareMenu" parent="Theme.Material3.Light.NoActionBar" />

      <!--
          The Activity window is transparent so the calling app remains
          visible behind the bottom sheet.
      -->
      <style name="Theme.ShareMenu.Transparent" parent="Theme.ShareMenu">
          <item name="android:windowBackground">@android:color/transparent</item>
          <item name="android:windowIsTranslucent">true</item>
          <item name="android:windowNoTitle">true</item>
          <item name="android:windowAnimationStyle">@null</item>
      </style>
  </resources>
  